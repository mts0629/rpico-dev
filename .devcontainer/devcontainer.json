{
    "build": {
        "dockerfile": "./Dockerfile",
        "context": ".",
        "args": {
            // Default user
            "USERNAME": "developer",
            "USER_UID": "1000",
            "USER_GID": "1000"
        }
    },
    "name": "rpico-dev",
    "containerEnv": {
        "TZ": "Asia/Tokyo"
    },
    "remoteEnv": {
        "PATH": "/workspaces/rpico-dev/pico-sdk-tools/build/openocd-install/usr/local/bin:/workspaces/rpico-dev/pico-sdk-tools/build/picotool-install/picotool:${containerEnv:PATH}"
    },
    "postCreateCommand": ".devcontainer/setup.sh",
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    }
                },
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "extensions": [
                "marus25.cortex-debug",
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-themes",
                "ms-vscode.vscode-serial-monitor"
            ]
        }
    }
}
